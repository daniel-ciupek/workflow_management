APP_NAME="Workflow Management"
APP_ENV=local               # production: change to "production"
APP_KEY=                    # run: php artisan key:generate
APP_DEBUG=false             # development: can set to "true"
APP_URL=http://localhost    # production: set to https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug             # production: set to "warning"

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=workflow_management
DB_USERNAME=workflow_user
DB_PASSWORD=                # required: set a strong random password

# ─── Session ─────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false       # production: set to "true"
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false # production: set to "true" (requires HTTPS)

# ─── Queue / Cache / Broadcast ───────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Mail (optional — currently logs to file) ────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─── Docker Compose ───────────────────────────────────────────────────────────
# Enables the Vite dev server container (node). Remove on production.
COMPOSE_PROFILES=dev
